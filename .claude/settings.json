{
  "enabledMcpjsonServers": ["playwright"],
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(mvn:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(git:*)",
      "Bash(tsc:*)",
      "Bash(java:*)",
      "Bash(bash -c*)",
      "mcp__playwright__*"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd frontend && npm run lint:fix 2>/dev/null; npx tsc --noEmit --pretty false 2>&1; cd ../backend && mvn compile -q 2>&1'",
            "timeout": 150,
            "statusMessage": "Checking compilation..."
          }
        ]
      }
    ]
  }
}
